                }
            },
            "random_camera_left_wrist_extrinsics": {
                "func": "randomize_camera_extrinsics",
                "mode": "reset",
                "params": {
                    "entity_cfg": {"uid": "cam_left_wrist"},
                    "pos_range": [[0.0, -0.02, 0.0], [0.02, 0.02, 0.01]],
