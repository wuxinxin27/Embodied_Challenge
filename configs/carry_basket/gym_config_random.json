                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },
            "random_milk_material": {
                "func": "randomize_visual_material",
                "mode": "interval",
                "interval_step": 10,
                "params": {
                    "entity_cfg": {"uid": "milk", "link_names": [".*"]},
                    "random_texture_prob": 0.5,
                    "texture_path": "/root/workspace/Embodied_Challenge/assets/background_texture/100",
                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },

      "init_milk_pose": {
        "func": "randomize_rigid_object_pose",
        "mode": "reset",
        "params": {
          "entity_cfg": {
            "uid": "milk"
          },
          "position_range": [[0.4, 0.1, 0.83], [0.65, 0.3, 0.83]],
          "relative_position": false
        }
      },
      "init_basket_pose": {
        "func": "randomize_rigid_object_pose",
        "mode": "reset",
        "params": {
          "entity_cfg": {
            "uid": "basket"
          },
          "position_range": [[0.4, -0.3, 0.83], [0.65, -0.1, 0.83]],
          "relative_position": false
        }
      },
            "randomize_distractor_slots": {
                "func": "replace_distractor_slots_from_library",
                "mode": "reset",
                "params": {
                    "entity_cfgs": [
                        {"uid": "distractor_0"},
                        {"uid": "distractor_1"}
                    ],
                    "library_index_path": "/root/workspace/Embodied_Challenge/embodied_challenge/Distractor/ASSET_INDEX.json",
                    "categories": ["PaperCup", "fork", "spoon"],
                    "position_ranges": [
                        [[0.4, -0.35, 0.89], [1.0, 0.35, 0.92]],
                        [[0.4, -0.35, 0.89], [1.0, 0.35, 0.92]]
                    ],
                    "appear_probs": [1.0, 1.0],
                    "z_rotation_ranges": [
                        [-180.0, 180.0],
                        [-180.0, 180.0]
                    ],
                    "hide_position": [0.0, 0.0, -10.0],
                    "avoid_uids": ["basket", "milk"],
                    "min_distance_to_avoid": 0.08,
                    "max_resample_attempts": 100,
                    "physics_update_step": 1
                }
            },
