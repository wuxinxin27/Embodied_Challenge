                    "instruction": {
                        "lang": "Click the bell"
                    },
                    "extra": {
                        "scene_type": "Sim",
                        "task_description": "Click the bell",
                        "data_type": "sim"
                    },
                    "use_videos": true
                }
            }
        },
        "control_parts": ["left_arm", "left_eef", "right_arm", "right_eef"]
