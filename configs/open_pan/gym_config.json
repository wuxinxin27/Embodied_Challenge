            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/embodichain/lab/gym/envs/tasks/tableware/open_pan/object/carrot_centered.obj",
                "compute_uv": true
            },
            "attrs": {
                "mass": 0.01,
                "contact_offset": 0.003,
                "rest_offset": 0.001,
                "restitution": 0.01,
