                0.593675
                ],
                "up": [
                0.865962,
                -0.009539,
                0.500019
                ]
            }
        },
        {
            "sensor_type": "Camera",
            "uid": "cam_right_wrist",
            "width": 640,
            "height": 480,
            "enable_mask": false,
            "intrinsics": [603.117004394531, 602.418640136719, 326.727478027344, 251.933990478516],
            "extrinsics": {
                "parent": "right_link6",
                "pos": [-0.12, 0.01, 0.03],
                "quat": [0.1949, 0.6797, -0.6797, -0.1949]
            }
        },
        {
            "sensor_type": "Camera",
            "uid": "cam_left_wrist",
            "width": 640,
            "height": 480,
            "enable_mask": false,
            "intrinsics": [603.117004394531, 602.418640136719, 326.727478027344, 251.933990478516],
            "extrinsics": {
                "parent": "left_link6",
                "pos": [-0.12, 0.01, 0.03],
                "quat": [0.1949, 0.6797, -0.6797, -0.1949]
            }
        }
    ],
    "light": {
        "direct": [
            {
                "uid": "light_1",
                "light_type": "point",
                "color": [1.0, 1.0, 1.0],
                "intensity": 50.0,
                "init_pos": [2.0, 0.0, 2.0],
                "radius": 10.0
            }
        ]
    },
    "background": [
        {
            "uid": "table",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "CircleTableSimple/circle_table_simple.ply",
                "compute_uv": true
            },
            "attrs": {
                "mass": 10.0,
                "static_friction": 0.95,
                "dynamic_friction": 0.9,
                "restitution": 0.01
            },
            "body_scale": [1.0, 1.0, 1.0],
            "body_type": "kinematic",
            "init_pos": [0.7, 0.0, 0.775],
            "init_rot": [0.0, 90.0, 0.0]
        }
    ],
    "rigid_object": [
        {
            "uid": "pan",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/embodichain/lab/gym/envs/tasks/tableware/open_pan/object/pot.ply",
                "compute_uv": true
            },
            "attrs": {
                "mass": 0.2,
                "contact_offset": 0.003,
                "rest_offset": 0.001,
                "restitution": 0.01,
                "max_depenetration_velocity": 10.0,
                "min_position_iters": 32,
                "min_velocity_iters": 8
            },
            "init_pos": [0.58, 0.06, 0.8],
