{
    "id": "DrawerOpenPlace-v1",
    "max_episodes": 1,
    "max_episode_steps": 900,
    "env": {
        "events": {
            "prepare_extra_attr": {
                "func": "prepare_extra_attr",
                "mode": "reset",
                "params": {
                    "attrs": [
                        {
                            "name": "left_arm_base_pose",
                            "mode": "callable",
                            "entity_cfg": {
                                "uid": "CobotMagic"
                            },
                            "func_name": "get_link_pose",
                            "func_kwargs": {
                                "link_name": "left_arm_base",
                                "to_matrix": true
                            }
                        },
                        {
                            "name": "right_arm_base_pose",
                            "mode": "callable",
                            "entity_cfg": {
                                "uid": "CobotMagic"
                            },
                            "func_name": "get_link_pose",
                            "func_kwargs": {
                                "link_name": "right_arm_base",
                                "to_matrix": true
                            }
                        },
                        {
                            "name": "nominal_drawer_xy",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "drawer"
                            },
                            "value": [0.9, 0.1]
                        },
                        {
                            "name": "drawer_pull_distance",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "drawer"
                            },
                            "value": -0.12
                        },
                        {
                            "name": "duck_grasp_offset_xyz",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "duck"
                            },
                            "value": [-0.015, 0.01, 0.015]
                        },
                        {
                            "name": "duck_hover_height",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "duck"
                            },
                            "value": 0.24
                        },
                        {
                            "name": "duck_pregrasp_height",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "duck"
                            },
                            "value": 0.1
                        },
                        {
                            "name": "drawer_inner_offset_xyz",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "drawer"
                            },
                            "value": [-0.04, 0.05, 0.295]
                        },
                        {
                            "name": "drawer_place_hover_offset_xyz",
                            "mode": "static",
                            "entity_cfg": {
                                "uid": "drawer"
                            },
                            "value": [0.0, 0.0, 0.12]
                        }
                    ]
                }
            },
            "register_info_to_env": {
                "func": "register_info_to_env",
                "mode": "reset",
                "params": {
                    "registry": [
                        {
                            "entity_cfg": {
                                "uid": "duck"
                            },
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": true,
                                "to_matrix": true
                            }
                        },
                        {
                            "entity_cfg": {
                                "uid": "drawer"
                            },
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": true,
                                "to_matrix": true
                            }
                        },
                        {
                            "entity_cfg": {
                                "uid": "CobotMagic",
                                "control_parts": ["left_arm"]
                            },
                            "attrs": ["left_arm_base_pose"],
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": false,
                                "to_matrix": true
                            },
                            "prefix": false
                        },
                        {
                            "entity_cfg": {
                                "uid": "CobotMagic",
                                "control_parts": ["right_arm"]
                            },
                            "attrs": ["right_arm_base_pose"],
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": false,
                                "to_matrix": true
                            },
                            "prefix": false
                        }
                    ],
                    "registration": "affordance_datas",
                    "sim_update": true
                }
            },
            "random_light": {
                "func": "randomize_light",
                "mode": "interval",
                "interval_step": 10,
                "params": {
                    "entity_cfg": {"uid": "light_1"},
                    "position_range": [[-0.5, -0.5, 2], [0.5, 0.5, 2]],
                    "color_range": [[0.6, 0.6, 0.6], [1, 1, 1]],
                    "intensity_range": [50.0, 100.0]
                }
            },
            "random_table_material": {
                "func": "randomize_visual_material",
                "mode": "interval",
                "interval_step": 2,
                "params": {
                    "entity_cfg": {"uid": "table"},
                    "random_texture_prob": 0.5,
                    "texture_path": "CocoBackground/coco",
                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },
            "random_duck_material": {
