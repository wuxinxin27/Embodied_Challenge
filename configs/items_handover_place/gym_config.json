            }
        }
    ],
    "light": {
        "direct": [
            {
                "uid": "light_1",
                "light_type": "point",
                "color": [1.0, 1.0, 1.0],
                "intensity": 50.0,
                "init_pos": [2, 0, 2],
                "radius": 10.0
            }
        ]
    },
    "background": [
        {
            "uid": "table",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "CircleTableSimple/circle_table_simple.ply",
                "compute_uv": true
            },
            "attrs" : {
                "mass": 10.0,
                "static_friction": 2.0,
                "dynamic_friction": 1.5,
                "restitution": 0.01,
                "contact_offset": 0.0002,
                "rest_offset": 0.00005
            },
            "body_scale": [1, 1, 1],
            "body_type": "kinematic",
            "init_pos": [0.725, 0.0, 0.7],
            "init_rot": [0, 90, 0]
        }
    ],
    "rigid_object": [
        {
            "uid":"holder",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/Embodied_Challenge/assets/PenHolder/pen_holder.obj",
                "compute_uv": true
            },
            "attrs" : {
                "mass": 0.005,
                "contact_offset": 0.003,
                "rest_offset": 0.001,
                "restitution": 0.1,
                "max_depenetration_velocity": 1e1,
                "min_position_iters": 32,
                "min_velocity_iters":8
            },
            "init_pos": [0.5, 0.1, 0.809],
            "init_rot": [90, 0, 0],
            "body_scale":[0.5, 0.75, 0.5],
            "max_convex_hull_num": 8
        },
        {
            "uid":"pen",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/Embodied_Challenge/assets/Pen/the_pen.obj",
                "compute_uv": true
            },
            "attrs" : {
                "mass": 0.005,
                "contact_offset": 0.003,
                "rest_offset": 0.001,
                "restitution": 0.01,
                "max_depenetration_velocity": 1e1,
                "min_position_iters": 32,
                "min_velocity_iters":8
            },
            "init_pos": [0.5, -0.1, 0.809],
            "init_rot": [0, 0, 0],
            "body_scale":[1, 1, 1],
