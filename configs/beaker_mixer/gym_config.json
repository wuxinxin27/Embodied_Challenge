            "intrinsics": [603.117004394531, 602.418640136719, 326.727478027344, 251.933990478516],
            "extrinsics": {
                "parent": "right_link6",
                "pos": [-0.12, 0.0, 0.04],
                "quat": [0.1976964, 0.69034543, -0.69034543, -0.1976964]
            }
        },
        {
            "sensor_type": "Camera",
            "uid": "cam_left_wrist",
            "width": 640,
            "height": 480,
            "enable_mask": false,
            "intrinsics": [603.117004394531, 602.418640136719, 326.727478027344, 251.933990478516],
            "extrinsics": {
                "parent": "left_link6",
                "pos": [-0.12, 0.0, 0.04],
                "quat": [0.1976964, 0.69034543, -0.69034543, -0.1976964]
            }
        }
    ],
    "light": {
        "direct": [
            {
                "uid": "light_1",
                "light_type": "point",
                "color": [1.0, 1.0, 1.0],
                "intensity": 50.0,
                "init_pos": [2.0, 0.0, 2.0],
                "radius": 10.0
            }
        ]
    },
    "background": [
        {
            "uid": "table",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "CircleTableSimple/circle_table_simple.ply",
                "compute_uv": true
            },
            "attrs" : {
                "mass": 10.0,
                "static_friction": 2.0,
                "dynamic_friction": 1.5,
                "restitution": 0.01,
                "contact_offset": 0.0002,
                "rest_offset": 0.00005
            },
            "body_scale": [1, 1, 1],
            "body_type": "kinematic",
            "init_pos": [0.725, 0.0, 0.7],
            "init_rot": [0, 90, 0]
        },
        {
            "uid": "beaker_mixer",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/RoboSynChallenge/assets/beaker_mixer/beaker_mixer.obj",
                "compute_uv": false
            },
            "attrs": {
                "mass": 1.0,
                "static_friction": 1.2,
                "dynamic_friction": 1.0,
                "contact_offset": 0.001,
                "rest_offset": 0.00025,
                "restitution": 0.0,
                "max_depenetration_velocity": 1.0,
                "min_position_iters": 32,
                "min_velocity_iters": 8,
                "enable_ccd": true
            },
            "body_scale": [0.3, 0.3, 0.3],
            "body_type": "kinematic",
            "max_convex_hull_num": 12,
            "init_pos": [0.7, 0.0, 0.795],
            "init_rot": [90, -90, 0]
        }
    ],
    "rigid_object": [
        {
            "uid": "beaker",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/RoboSynChallenge/assets/Beaker/beaker.ply",
                "compute_uv": true
            },
            "attrs": {
                "mass": 0.1,
                "contact_offset": 0.001,
                "static_friction": 1.5,
                "dynamic_friction": 0.3,
                "rest_offset": 0.00025,
                "restitution": 0.0,
                "max_depenetration_velocity": 1.0,
                "min_position_iters": 32,
                "min_velocity_iters": 8,
                "enable_ccd": true
            },
            "body_scale": [1.1, 1.1, 1.1],
            "max_convex_hull_num": 24,
            "init_pos": [0.7, -0.2, 0.755],
            "init_rot": [0, 0, 0]
        },
        {
            "uid": "distractor_0",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/RoboSynChallenge/assets/Beaker/beaker.ply",
                "compute_uv": true
            }
        },
        {
            "uid": "distractor_1",
            "shape": {
                "shape_type": "Mesh",
                "fpath": "/root/workspace/RoboSynChallenge/assets/Beaker/beaker.ply",
                "compute_uv": true
            }
        }
    ]
}
