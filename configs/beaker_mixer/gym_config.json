{
    "id": "BeakerMixer-v0",
    "max_episodes": 10,
    "max_episode_steps": 500,
    "env": {
        "events": {
            "random_light": {
                "func": "randomize_light",
                "mode": "interval",
                "interval_step": 10,
                "params": {
                    "entity_cfg": {"uid": "light_1"},
                    "position_range": [[-0.5, -0.5, 2], [0.5, 0.5, 2]],
                    "color_range": [[0.6, 0.6, 0.6], [1.0, 1.0, 1.0]],
                    "intensity_range": [50.0, 100.0]
                }
            },
            "random_beaker_pose": {
                "func": "randomize_rigid_object_pose",
                "mode": "reset",
                "params": {
                    "entity_cfg": {"uid": "beaker"},
                    "position_range": [[-0.08, -0.02, 0.0], [0.08, 0.02, 0.0]],
                    "rotation_range": [[0, 0, -90], [0, 0, 90]],
                    "relative_position": true,
                    "relative_rotation": true
                }
            },
            "random_beaker_mixer_pose": {
                "func": "randomize_rigid_object_pose",
                "mode": "reset",
                "params": {
                    "entity_cfg": {"uid": "beaker_mixer"},
                    "position_range": [[0, 0, 0.0], [0, 0, 0.0]],
                    "rotation_range": [[0, 0, 0], [0, 0, 0]],
                    "relative_position": true,
                    "relative_rotation": true
                }
            },
            "random_robot_material": {
                "func": "randomize_visual_material",
                "mode": "interval",
                "interval_step": 5,
                "params": {
                    "entity_cfg": {"uid": "CobotMagic", "link_names": [".*"]},
                    "random_texture_prob": 0.5,
                    "texture_path": "CocoBackground/coco",
                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },
            "random_table_material": {
                "func": "randomize_visual_material",
                "mode": "interval",
                "interval_step": 2,
                "params": {
                    "entity_cfg": {"uid": "table"},
                    "random_texture_prob": 0.5,
                    "texture_path": "CocoBackground/coco",
                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },
            "random_beaker_material": {
                "func": "randomize_visual_material",
                "mode": "interval",
                "interval_step": 8,
                "params": {
                    "entity_cfg": {"uid": "beaker"},
                    "random_texture_prob": 0.5,
                    "texture_path": "CocoBackground/coco",
                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },
            "random_beaker_mixer_material": {
                "func": "randomize_visual_material",
                "mode": "interval",
                "interval_step": 8,
                "params": {
                    "entity_cfg": {"uid": "beaker_mixer"},
                    "random_texture_prob": 0.5,
                    "texture_path": "CocoBackground/coco",
                    "base_color_range": [[0.2, 0.2, 0.2], [1.0, 1.0, 1.0]]
                }
            },
            "random_camera_intrinsics": {
                "func": "randomize_camera_intrinsics",
                "mode": "reset",
                "params": {
                    "entity_cfg": {"uid": "cam_high"},
                    "focal_x_range": [-50, 50],
                    "focal_y_range": [-50, 50]
                }
            },
            "random_robot_init_eef_pose": {
                "func": "randomize_robot_eef_pose",
                "mode": "reset",
                "params": {
                    "entity_cfg": {"uid": "CobotMagic", "control_parts": ["left_arm", "right_arm"]},
                    "position_range": [[-0.01, -0.01, -0.01], [0.01, 0.01, 0.0]]
                }
            },
            "prepare_extra_attr": {
                "func": "prepare_extra_attr",
                "mode": "reset",
                "params": {
                    "attrs": [
                        {
                            "name": "right_arm_base_pose",
                            "mode": "callable",
                            "entity_cfg": {"uid": "CobotMagic"},
                            "func_name": "get_link_pose",
                            "func_kwargs": {
                                "link_name": "right_arm_base",
                                "to_matrix": true
                            }
                        },
                        {
                            "name": "grasp_offset_intrinsic_z",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker"},
                            "value": 0.018
                        },
                        {
                            "name": "grasp_offset_intrinsic_rotation_y",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker"},
                            "value": -15
                        },
                        {
                            "name": "place_offset_extrinsic_z",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": 0.08
                        },
                        {
                            "name": "place_offset_intrinsic_z",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": -0.05
                        },
                        {
                            "name": "button_offset_x",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": 0.11175
                        },
                        {
                            "name": "button_offset_y",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": -0.006
                        },
                        {
                            "name": "button_offset_z",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": 0.042
                        },
                        {
                            "name": "button_rotation_x",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": 10
                        },
                        {
                            "name": "button_rotation_y",
                            "mode": "static",
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "value": -10
                        }
                    ]
                }
            },
            "register_info_to_env": {
                "func": "register_info_to_env",
                "mode": "reset",
                "params": {
                    "registry": [
                        {
                            "entity_cfg": {"uid": "beaker"},
                            "attrs": ["grasp_offset_intrinsic_z", "grasp_offset_intrinsic_rotation_y"],
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": false,
                                "to_matrix": true
                            },
                            "prefix": true
                        },
                        {
                            "entity_cfg": {"uid": "beaker_mixer"},
                            "attrs": [
                                "place_offset_extrinsic_z",
                                "place_offset_intrinsic_z",
                                "button_offset_x",
                                "button_offset_y",
                                "button_offset_z",
                                "button_rotation_x",
                                "button_rotation_y"
                            ],
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": false,
                                "to_matrix": true
                            },
                            "prefix": true
                        },
                        {
                            "entity_cfg": {"uid": "CobotMagic", "control_parts": ["right_arm"]},
                            "attrs": ["right_arm_base_pose"],
                            "pose_register_params": {
                                "compute_relative": false,
                                "compute_pose_object_to_arena": false,
                                "to_matrix": true
                            },
                            "prefix": false
                        }
                    ],
                    "registration": "affordance_datas",
                    "sim_update": true
                }
            },
            "visualize_beaker_mixer_pose": {
                "func": "visualize_affordance_pose",
                "mode": "reset",
                "params": {
                    "pose_key": "beaker_mixer_pose",
                    "marker_name": "beaker_mixer_pose_marker",
                    "axis_size": 0.004,
                    "axis_len": 0.2,
                    "arena_index": 0,
                    "remove_old": true
                }
            }
        },
        "observations": {
            "norm_robot_eef_joint": {
                "func": "normalize_robot_joint_data",
                "mode": "modify",
                "name": "robot/qpos",
                "params": {
                    "joint_ids": [6, 13]
                }
            },
            "beaker_pose": {
                "func": "get_rigid_object_pose",
                "mode": "add",
                "name": "beaker_pose",
                "params": {
                    "entity_cfg": {"uid": "beaker"}
                }
            },
            "beaker_mixer_pose": {
                "func": "get_rigid_object_pose",
                "mode": "add",
                "name": "beaker_mixer_pose",
                "params": {
                    "entity_cfg": {"uid": "beaker_mixer"}
                }
            }
        },
        "dataset": {
            "robot_meta": {
                "arm_dofs": 12,
                "control_freq": 25,
                "control_parts": ["left_arm", "left_eef", "right_arm", "right_eef"],
                "min_len_steps": 5
            }
        },
        "control_parts": ["left_arm", "left_eef", "right_arm", "right_eef"]
    },
    "robot": {
        "uid": "CobotMagic",
        "robot_type": "CobotMagic",
        "init_pos": [0.0, 0.0, 0.7775],
        "init_qpos": [-0.3, 0.3, 1.0, 1.0, -1.2, -1.2, 0.0, 0.0, 0.6, 0.6, 0.0, 0.0, 0.05, 0.05, 0.05, 0.05]
    },
