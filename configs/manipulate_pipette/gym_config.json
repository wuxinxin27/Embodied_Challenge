        }

    ],
    "articulation": [
        {
            "uid": "pipette",
            "fpath": "/root/workspace/Embodied_Challenge/assets/pipette_good/pipette_good.usda",
            "build_pk_chain": false,
            "init_pos": [0.6, -0.25, 0.88],
            "init_rot": [0, 0, 0],
            "init_qpos": [0.5],
            "fix_base": false,
