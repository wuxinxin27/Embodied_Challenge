        {
            "sensor_type": "Camera",
            "uid": "cam_left_wrist",
            "width": 64,
            "height": 48,
            "enable_mask": true,
            "intrinsics": [488.1665344238281, 488.1665344238281, 322.7323303222656, 213.17434692382812],
            "extrinsics": {
                "parent": "left_link6",
                "pos": [-0.08, 0.0, 0.04],
                "quat": [0.15304635, 0.69034543, -0.69034543, -0.15304635]
            }
        }
    ],
    "light": {
        "direct": [
            {
                "uid": "light_1",
                "light_type": "point",
                "color": [1.0, 1.0, 1.0],
                "intensity": 50.0,
