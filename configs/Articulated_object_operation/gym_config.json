                    "extra": {
                        "scene_type": "Sim",
                        "task_description": "achieve precise alignment of the silicone columns",
                        "data_type": "sim"
                    },
                    "use_videos": true
                }
            }
        },
        "control_parts": ["left_arm", "left_eef", "right_arm", "right_eef"]
